{
	"info": {
		"name": "MBF Scan Service API",
		"description": "Postman collection for MBF Scan Service - API đặc tả cho FE tích hợp",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "System",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Kiểm tra trạng thái service"
					},
					"response": []
				}
			]
		},
		{
			"name": "Scanner",
			"item": [
				{
					"name": "1. List Scanners",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/list",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "list"]
						},
						"description": "Lấy danh sách máy scan khả dụng"
					},
					"response": []
				},
				{
					"name": "2. Scan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scannerName\": \"FUJITSU fi-760\",\n  \"settings\": {\n    \"dpi\": 300,\n    \"colorMode\": \"Color\",\n    \"paperSize\": \"A4\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/scan",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "scan"]
						},
						"description": "Khởi tạo session và quét (blocking - đợi user scan xong). Sau khi nhận response, copy giá trị `sessionId` vào biến {{sessionId}} để dùng cho các API tiếp theo."
					},
					"response": []
				},
				{
					"name": "3. Detect Files",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"number\": 12345678\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/pages",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "pages"]
						},
						"description": "Detect barcode, group pages thành files và trả về preview file names.\n\nResponse trả về cấu trúc:\n{\n  \"number\": 12345678,\n  \"totalPages\": 5,\n  \"totalFiles\": 2,\n  \"files\": [\n    {\n      \"fileName\": \"12345678_13042026_105604.pdf\",\n      \"pages\": [\n        { \"pageIndex\": 0, ... },\n        { \"pageIndex\": 1, ... }\n      ]\n    }\n  ]\n}"
					},
					"response": []
				},
				{
					"name": "4. Get Page Preview",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/preview/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "preview", "0"]
						},
						"description": "Xem preview hình ảnh của page index 0. Trả về hình ảnh (JPEG/PNG/TIFF).\n\nThay đổi số cuối URL để xem page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "5. Get Page PDF",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/page-pdf/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "page-pdf", "0"]
						},
						"description": "Lấy file PDF của page index 0. Trả về file PDF.\n\nThay đổi số cuối URL để xem page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "6. Delete Page",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/pages/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "pages", "0"]
						},
						"description": "Xóa page tại index 0.\n\nThay đổi số cuối URL để xóa page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "7. Process Scan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"number\": 12345678,\n  \"files\": [\n    {\n      \"fileName\": \"12345678_13042026_105604.pdf\",\n      \"pageIndices\": [0, 1]\n    },\n    {\n      \"fileName\": \"12345678_13042026_105604_1.pdf\",\n      \"pageIndices\": [2, 3, 4]\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/process",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "process"]
						},
						"description": "Tạo PDF và OCR theo danh sách file từ client.\n\nBody params:\n- `number`: số hồ sơ\n- `files[]`: danh sách file cần tạo\n- `files[].fileName`: tên file PDF (do client quyết định)\n- `files[].pageIndices`: danh sách page indices để ghép thành file"
					},
					"response": []
				}
			]
		},
		{
			"name": "Files",
			"item": [
				{
					"name": "Download File",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "files", "{fileId}"]
						},
						"description": "Download file PDF bằng fileId."
					},
					"response": []
				},
				{
					"name": "Get All Stored Files",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/stored-files",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "stored-files"]
						},
						"description": "Lấy danh sách tất cả file PDF đã được tạo và lưu trữ."
					},
					"response": []
				},
				{
					"name": "Get File (PDF - inline)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "files", "{fileId}"]
						},
						"description": "Lấy file PDF để hiển thị inline (không force download)."
					},
					"response": []
				},
				{
					"name": "Delete File",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "files", "{fileId}"]
						},
						"description": "Xóa file PDF đã lưu."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string",
			"description": "Session ID - copy từ response của Scan API sau khi quét xong"
		},
		{
			"key": "fileId",
			"value": "",
			"type": "string",
			"description": "File ID - copy từ response của Process Scan"
		}
	]
}
