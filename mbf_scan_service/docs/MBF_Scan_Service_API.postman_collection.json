{
	"info": {
		"name": "MBF Scan Service API",
		"description": "Postman collection for MBF Scan Service - API đặc tả cho FE tích hợp. Hỗ trợ scan, OCR và ký số (Token/SIM).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "System",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Kiểm tra trạng thái service"
					},
					"response": []
				}
			]
		},
		{
			"name": "Scanner",
			"item": [
				{
					"name": "1. List Scanners",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/list",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "list"]
						},
						"description": "Lấy danh sách máy scan khả dụng"
					},
					"response": []
				},
				{
					"name": "2. Scan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scannerName\": \"FUJITSU fi-760\",\n  \"settings\": {\n    \"dpi\": 300,\n    \"colorMode\": \"Color\",\n    \"paperSize\": \"A4\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/scan",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "scan"]
						},
						"description": "Khởi tạo session và quét (blocking - đợi user scan xong). Sau khi nhận response, copy giá trị `sessionId` vào biến {{sessionId}} để dùng cho các API tiếp theo."
					},
					"response": []
				},
				{
					"name": "3. Detect Files",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/pages",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "pages"]
						},
						"description": "Detect barcode, group pages thành documents và files.\n\nResponse trả về cấu trúc:\n{\n  \"totalPages\": 8,\n  \"totalDocuments\": 2,\n  \"totalFiles\": 3,\n  \"documents\": [\n    {\n      \"docIndex\": 0,\n      \"files\": [\n        {\n          \"fileIndex\": 0,\n          \"pageCount\": 2,\n          \"pages\": [\n            { \"pageIndex\": 0, \"imageUrl\": \"...\", \"isDocSeparator\": false, ... },\n            { \"pageIndex\": 1, \"imageUrl\": \"...\", \"isDocSeparator\": false, ... }\n          ]\n        }\n      ]\n    }\n  ]\n}\n\nBarcode Separator:\n- Doc_Separate: Tách thành document mới\n- File_Separate: Tách thành file mới trong cùng document"
					},
					"response": []
				},
				{
					"name": "4. Get Page Preview",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/preview/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "preview", "0"]
						},
						"description": "Xem preview hình ảnh của page index 0. Trả về hình ảnh (JPEG/PNG/TIFF).\n\nThay đổi số cuối URL để xem page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "5. Get Page PDF",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/page-pdf/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "page-pdf", "0"]
						},
						"description": "Lấy file PDF của page index 0. Trả về file PDF.\n\nThay đổi số cuối URL để xem page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "6. Delete Page",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/pages/0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "pages", "0"]
						},
						"description": "Xóa page tại index 0.\n\nThay đổi số cuối URL để xóa page khác (0-based index)."
					},
					"response": []
				},
				{
					"name": "7. Process Scan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							},
							{
								"key": "X-Web-Token",
								"value": "",
								"description": "Web token (bắt buộc nếu cần ký số)"
							},
							{
								"key": "X-Role-Id",
								"value": "",
								"description": "Role ID (bắt buộc nếu cần ký SIM)"
							},
							{
								"key": "X-User-Id",
								"value": "",
								"description": "User ID (bắt buộc nếu cần ký SIM)"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"documents\": [\n    {\n      \"docIndex\": 0,\n      \"files\": [\n        {\n          \"docIndex\": 0,\n          \"fileIndex\": 0,\n          \"fileName\": \"doc1_file1.pdf\",\n          \"pages\": [\n            { \"index\": 0, \"isOCR\": true },\n            { \"index\": 1, \"isOCR\": true }\n          ],\n          \"signInfo\": {\n            \"phone\": \"0912345678\",\n            \"messageToBeDisplayed\": \"\",\n            \"filePath\": \"\",\n            \"fileBase64\": \"\",\n            \"fileName\": \"doc1_file1.pdf\",\n            \"uploadUrl\": \"/upload-signed\",\n            \"signType\": 0,\n            \"folderKey\": \"folder-123\",\n            \"listSignatureInfo\": [\n              {\n                \"page\": 1,\n                \"x\": 100.00,\n                \"y\": 50.00,\n                \"signType\": \"IMAGE\",\n                \"text\": \"\",\n                \"imageWidth\": 135,\n                \"imageHeight\": 75,\n                \"base64Image\": \"iVBORw0KGgoAAAANSUhEUg...\"\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/process",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "process"]
						},
						"description": "Tạo PDF, OCR và ký số (tùy chọn).\n\nHeaders bắt buộc cho ký số:\n- X-Web-Token: Web token authentication\n- X-Role-Id: Role ID của user\n- X-User-Id: User ID của user\n\nSignType:\n- 0: Ký Token (không cần X-Role-Id, X-User-Id)\n- 1: Ký SIM (cần tất cả headers)\n\nResponse trả về thêm các fields:\n- signedFileUrl: URL file đã ký\n- signedFilePath: Server path của file đã ký\n- signSuccess: Trạng thái ký số"
					},
					"response": []
				},
				{
					"name": "7a. Process Scan (With Sign - Token)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							},
							{
								"key": "X-Web-Token",
								"value": "",
								"description": "Web token cho ký Token"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"documents\": [\n    {\n      \"docIndex\": 0,\n      \"files\": [\n        {\n          \"docIndex\": 0,\n          \"fileIndex\": 0,\n          \"fileName\": \"doc1_file1.pdf\",\n          \"pages\": [\n            { \"index\": 0, \"isOCR\": true }\n          ],\n          \"signInfo\": {\n            \"phone\": \"0912345678\",\n            \"signType\": 0,\n            \"listSignatureInfo\": [\n              {\n                \"page\": 1,\n                \"x\": 100.00,\n                \"y\": 50.00,\n                \"signType\": \"IMAGE\",\n                \"imageWidth\": 135,\n                \"imageHeight\": 75,\n                \"base64Image\": \"iVBORw0KGgoAAAANSUhEUg...\"\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/process",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "process"]
						},
						"description": "Process scan với ký Token (SignType = 0).\n\nChỉ cần X-Web-Token, không cần X-Role-Id và X-User-Id."
					},
					"response": []
				},
				{
					"name": "7b. Process Scan (With Sign - SIM)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Session-Id",
								"value": "{{sessionId}}",
								"description": "Session ID từ response của Scan API"
							},
							{
								"key": "X-Web-Token",
								"value": "",
								"description": "Web token"
							},
							{
								"key": "X-Role-Id",
								"value": "",
								"description": "Role ID"
							},
							{
								"key": "X-User-Id",
								"value": "",
								"description": "User ID"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"documents\": [\n    {\n      \"docIndex\": 0,\n      \"files\": [\n        {\n          \"docIndex\": 0,\n          \"fileIndex\": 0,\n          \"fileName\": \"doc1_file1.pdf\",\n          \"pages\": [\n            { \"index\": 0, \"isOCR\": true }\n          ],\n          \"signInfo\": {\n            \"phone\": \"0912345678\",\n            \"signType\": 1,\n            \"listSignatureInfo\": [\n              {\n                \"page\": 1,\n                \"x\": 100.00,\n                \"y\": 50.00,\n                \"signType\": \"IMAGE\",\n                \"imageWidth\": 135,\n                \"imageHeight\": 75,\n                \"base64Image\": \"iVBORw0KGgoAAAANSUhEUg...\"\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/scanner/process",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "process"]
						},
						"description": "Process scan với ký SIM (SignType = 1).\n\nCần tất cả headers: X-Web-Token, X-Role-Id, X-User-Id."
					},
					"response": []
				}
			]
		},
		{
			"name": "Files",
			"item": [
				{
					"name": "Download File",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "files", "{fileId}"]
						},
						"description": "Download file PDF bằng fileId."
					},
					"response": []
				},
				{
					"name": "Get All Stored Files",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/stored-files",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "stored-files"]
						},
						"description": "Lấy danh sách tất cả file PDF đã được tạo và lưu trữ."
					},
					"response": []
				},
				{
					"name": "Get File (PDF - inline)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "files", "{fileId}"]
						},
						"description": "Lấy file PDF để hiển thị inline (không force download)."
					},
					"response": []
				},
				{
					"name": "Delete File",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/scanner/files/{fileId}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "scanner", "files", "{fileId}"]
						},
						"description": "Xóa file PDF đã lưu."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "sessionId",
			"value": "",
			"type": "string",
			"description": "Session ID - copy từ response của Scan API sau khi quét xong"
		},
		{
			"key": "fileId",
			"value": "",
			"type": "string",
			"description": "File ID - copy từ response của Process Scan"
		},
		{
			"key": "webToken",
			"value": "",
			"type": "string",
			"description": "Web token cho authentication (bắt buộc khi ký số)"
		},
		{
			"key": "roleId",
			"value": "",
			"type": "string",
			"description": "Role ID - bắt buộc khi ký SIM"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string",
			"description": "User ID - bắt buộc khi ký SIM"
		}
	]
}
